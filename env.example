# Swiss Ephemeris API Configuration
SWISS_API_BASE_URL=https://api.swissephemeris.com/v1
SWISS_API_KEY=your_swiss_api_key_here

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_openai_org_id_here

# OpenAI Assistant IDs
ASTRO_INTERPRETER_ASSISTANT_ID=asst_your_interpreter_id
EMAIL_FORMATTER_ASSISTANT_ID=asst_your_email_formatter_id
CYPHER_GENERATOR_ASSISTANT_ID=asst_your_cypher_generator_id

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=recipient@example.com

# Location Configuration (for astronomical calculations)
LATITUDE=40.7128
LONGITUDE=-74.0060
TIMEZONE=America/New_York

# Scheduling Configuration
SCHEDULE_HOUR=6
SCHEDULE_MINUTE=0
PLANETARY_HOUR_SCHEDULING=false

# Application Configuration
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=false

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY=5
EXPONENTIAL_BACKOFF=true
